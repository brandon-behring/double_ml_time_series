# PDF
*.pdf

# But keep generated PDFs in specific output directory for milestones
!docs/output/*.pdf

# Test results and logs
test_results*.txt
# Frozen audit/validation evidence (2025-11 runs) is intentionally tracked as
# audit artifacts, referenced by docs/archive/* and the audit trail. New ad-hoc
# dumps under results/ stay ignored; the four evidence subdirs below are kept.
results/*
!results/impact_analysis/
!results/lasso_diagnostic/
!results/method_comparison/
!results/simulations/
logs/

# Sensitive
.env
.env.local
*.key
credentials.json

# v4.6 prevalidate migration (2026-05-27): explicit exception for web/.env,
# which carries BOOK_PROFILE=academic only (non-sensitive — same convention as
# ssm-foundations which tracks its .env). Required for CI to pick up the
# profile without per-script BOOK_PROFILE prefixes after migrating from
# ci:validate to the npm prevalidate lifecycle hook. See book-scaffold-astro
# recipe 19 + ~/.claude/projects/.../memory/dogfood-loop.md.
!web/.env

# Large files
*.db
*.sqlite
*.h5
*.hdf5

# But keep validation registry
!notebooks/validation/VALIDATION_REGISTRY.md

# Security - secrets and credentials
*.pem
*credentials*
*.secret

# Sphinx documentation build
docs/sphinx/_build/

# Claude local overrides (machine-specific)
.claude/settings.local.json
/books/
