{
  "permissions": {
    "allow": [
      "Write(**)",
      "Edit(**)",
      "Bash(bibtex:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/credentials*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo:*)",
      "Bash(su:*)"
    ],
    "defaultMode": "bypassPermissions"
  }
}

